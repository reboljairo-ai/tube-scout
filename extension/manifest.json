{
  "manifest_version": 3,
  "name": "TubeScout — YouTube Niche Analyzer",
  "version": "1.0.5",
  "description": "Find viral YouTube niches, analyze competitors, and discover content opportunities before anyone else.",
  "permissions": ["storage", "activeTab", "sidePanel"],
  "host_permissions": ["https://www.youtube.com/*"],
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [{
    "matches": ["https://www.youtube.com/watch*"],
    "js": ["content.js"],
    "css": ["content.css"]
  }],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
